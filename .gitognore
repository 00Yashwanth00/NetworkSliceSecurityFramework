.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# =========================
# Java & Maven (DataScraping)
# =========================
# Compiled class files and Maven output
target/
*.class

# Log files
*.log

# Packaged archives
# Note: Comment these out if you intentionally want to commit specific .jar files
*.jar
*.war
*.ear
*.zip
*.tar.gz

# =========================
# Python & ML (ML_Model)
# =========================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual Environments (Like the 'env' you excluded in your tree)
env/
venv/
.venv/
env.bak/
venv.bak/

# distribution/packaging
build/
dist/
*.egg-info/
.eggs/

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# =========================
# IDEs and Editors
# =========================
# VS Code
.vscode/

# IntelliJ IDEA / PyCharm (JetBrains)
.idea/
*.iml
*.iws

# Eclipse
.classpath
.project
.settings/
.apt_generated/

# =========================
# Data & Large Models (PLEASE READ BELOW)
# =========================
# GitHub blocks files over 100MB. If your datasets or trained models 
# exceed this size, uncomment the lines below to ignore them.
# Otherwise, Git will track them.
#
ML_Model/data/raw/*.csv
ML_Model/data/processed/*.csv
ML_Model/models/saved_models/*.keras
ML_Model/models/saved_models/*.pkl
ML_Model/models/saved_models/*.json
ML_Model/models/scalers/*.pkl
